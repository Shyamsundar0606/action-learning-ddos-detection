<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loading...</title>
    <style>
        body {
            font-family: 'Inter', sans-serif; /* Using Inter font */
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            background-color: #f0f2f5; /* Light grey background */
            color: #333;
            text-align: center;
            padding: 20px;
            box-sizing: border-box;
        }

        .container {
            background-color: #ffffff;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            max-width: 500px;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 25px;
        }

        .logo {
            margin-bottom: 15px;
        }

        .logo img {
            max-width: 180px; /* Slightly larger logo for a loading page */
            height: auto;
            border-radius: 8px;
        }

        h1 {
            font-size: 1.8em;
            color: #2c3e50;
            margin-bottom: 10px;
        }

        p {
            font-size: 1.1em;
            line-height: 1.6;
            margin-bottom: 25px;
        }

        /* Loading Spinner CSS */
        .spinner {
            border: 8px solid #f3f3f3; /* Light grey */
            border-top: 8px solid #3498db; /* Blue */
            border-radius: 50%;
            width: 60px;
            height: 60px;
            animation: spin 1s linear infinite; /* Spin animation */
            margin-top: 20px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Responsive adjustments */
        @media (max-width: 600px) {
            .container {
                padding: 25px;
                margin: 15px;
            }
            h1 {
                font-size: 1.5em;
            }
            p {
                font-size: 1em;
            }
            .spinner {
                width: 40px;
                height: 40px;
                border-width: 6px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="logo">
            <!-- Replace 'https://placehold.co/180x60/000000/FFFFFF?text=Your+Logo' with your actual project logo URL -->
            <img src="https://i.imgur.com/RA29550.png" alt="Project Logo">
        </div>

        <h1>Loading...</h1>
        <p>Please wait while we prepare your content.</p>
        <p>This may take a moment.</p>

        <div class="spinner"></div>

        <!-- Optional: A script to redirect after a delay or when content is ready -->
        <script>
            // Example: Redirect after 3 seconds (3000 milliseconds)
            // You would replace this with actual logic to check if your content is loaded
            /*
            setTimeout(() => {
                window.location.href = '/dashboard'; // Redirect to your main application page
            }, 3000);
            */
        </script>
    </div>
</body>
</html>
